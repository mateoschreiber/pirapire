{"nodes": [{"id": "_opencode_skills_graphify_references_extraction_spec_extraction_subagent", "label": "Graphify Extraction Subagent", "file_type": "document", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_opencode_skills_graphify_references_extraction_spec_confidence_rubric", "label": "Graphify Confidence Score Rubric", "file_type": "rationale", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Discrete confidence score tiers for INFERRED edges (0.95, 0.85, 0.75, 0.65, 0.55) to avoid bimodal distribution collapse at 0.5. EXTRACTED=1.0, AMBIGUOUS=0.1-0.3."}, {"id": "_opencode_skills_graphify_references_extraction_spec_node_id_format", "label": "Graphify Node ID Format Convention", "file_type": "rationale", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Node IDs use full repo-relative path stems joined with underscores, keeping every directory level so same-named files in different directories stay distinct. Never append chunk numbers."}, {"id": "_opencode_skills_graphify_references_extraction_spec_hyperedges", "label": "Graphify Hyperedges", "file_type": "concept", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Capture shared concepts/flows/patterns among 3+ nodes that are not captured by pairwise edges alone. Used sparingly, max 3 per chunk."}, {"id": "_opencode_skills_graphify_references_extraction_spec_semantic_similarity", "label": "Graphify Semantic Similarity Edge", "file_type": "concept", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Links two concepts that solve the same problem without any structural link (no import, call, or citation). Confidence 0.6-0.95."}, {"id": "_opencode_skills_graphify_references_extraction_spec_source_file_rule", "label": "Graphify source_file Verbatim Rule", "file_type": "rationale", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "source_file must be verbatim from FILE_LIST, never shortened. This keeps the full build and incremental --update on the same base so build_merge's replace-on-re-extract matches the existing node."}, {"id": "_opencode_skills_graphify_references_extraction_spec_cross_language_guard", "label": "Graphify Cross-Language Call Guard", "file_type": "rationale", "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "calls edges MUST stay within one language; a Python function cannot call a JS/TS/Go/Rust/Java symbol. Cross-language call edges are phantom artifacts."}], "edges": [{"source": "_opencode_skills_graphify_references_extraction_spec_extraction_subagent", "target": "_opencode_skills_graphify_references_extraction_spec_confidence_rubric", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".opencode/skills/graphify/references/extraction-spec.md", "source_location": null, "weight": 1.0}, {"source": "_opencode_skills_graphify_references_extraction_spec_extraction_subagent", "target": "_opencode_skills_graphify_references_extraction_spec_node_id_format", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.