{"nodes": [{"id": "_opencode_skills_graphify_skill_graphify", "label": "Graphify Knowledge Graph Tool", "file_type": "document", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Turns any folder of code, docs, papers, images, or video into a queryable knowledge graph with community detection, an honest audit trail, and multiple output formats."}, {"id": "_opencode_skills_graphify_skill_extraction_pipeline", "label": "Graphify Extraction Pipeline", "file_type": "concept", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Multi-step pipeline: detect files, transcribe media, extract AST (deterministic) + semantic (LLM), merge, build graph, cluster, analyze god nodes and surprising connections, generate report, label communities, produce outputs."}, {"id": "_opencode_skills_graphify_skill_ast_extraction", "label": "AST Structural Extraction", "file_type": "concept", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Deterministic, free extraction of code files using AST analysis - no LLM needed. Handles imports, calls, class hierarchy."}, {"id": "_opencode_skills_graphify_skill_semantic_extraction", "label": "Semantic Extraction (LLM)", "file_type": "concept", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "LLM-based extraction for docs, papers, and images. Uses Gemini if API key is set, otherwise falls back to the host agent as the LLM. Code-only corpora skip this entirely."}, {"id": "_opencode_skills_graphify_skill_community_detection", "label": "Graphify Community Detection", "file_type": "concept", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_opencode_skills_graphify_skill_god_nodes", "label": "Graphify God Nodes Analysis", "file_type": "concept", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_opencode_skills_graphify_skill_audit_trail", "label": "Graphify Audit Trail (EXTRACTED/INFERRED/AMBIGUOUS)", "file_type": "rationale", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Every edge carries a confidence tag (EXTRACTED/INFERRED/AMBIGUOUS) providing an honest audit trail so the user knows what evidence supports each relationship."}, {"id": "_opencode_skills_graphify_skill_graphifyy", "label": "Graphifyy Python Package", "file_type": "code", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "_opencode_skills_graphify_skill_gemini_api", "label": "Gemini API Backend", "file_type": "document", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "No API key is required for graphify. Gemini is optional for semantic extraction; the host agent itself falls back as the LLM when no key is set."}, {"id": "_opencode_skills_graphify_skill_fast_path", "label": "Graphify Fast Path (Existing Graph)", "file_type": "rationale", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "When graph.json already exists, skip extraction/build and jump to query/path/explain immediately. Avoids rebuild for questions against an existing graph."}, {"id": "_opencode_skills_graphify_skill_graph_shrink_guard", "label": "Graphify Graph Shrink Guard", "file_type": "rationale", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Prevents graph.json from being overwritten by a smaller graph (#479). Only allows the build if the new graph is at least as large as the existing one."}, {"id": "_opencode_skills_graphify_skill_honesty_rules", "label": "Graphify Honesty Rules", "file_type": "rationale", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core design principles: never invent an edge, never skip corpus check warning, always show token cost, never hide cohesion scores, never run HTML viz on graphs > 5000 nodes without warning."}, {"id": "_opencode_skills_graphify_skill_surprising_connections", "label": "Graphify Surprising Connections Analysis", "file_type": "concept", "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}], "edges": [{"source": "_opencode_skills_graphify_skill_graphify", "target": "_opencode_skills_graphify_skill_extraction_pipeline", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_opencode_skills_graphify_skill_extraction_pipeline", "target": "_opencode_skills_graphify_skill_ast_extraction", "relation": "conceptually_related_to", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": ".opencode/skills/graphify/SKILL.md", "source_location": null, "weight": 1.0}, {"source": "_opencode_skills_graphify_skill_extraction_pipeline", "target": "_openco