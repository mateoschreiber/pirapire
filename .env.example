APP_NAME=Pirapire
APP_ENV=local
DATABASE_URL=sqlite:////app/data/pirapire.db
LOG_LEVEL=INFO

# --- Football sources ---
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITIONS=WC,CL,PL,BL1,SA,PD,FL1
FOOTBALL_DATA_REQUEST_DELAY_SECONDS=7
FOOTBALL_DATA_MAX_COMPETITIONS_PER_RUN=3
FOOTBALL_DATA_RESPECT_RETRY_AFTER=true
OPENLIGADB_LEAGUE_SHORTCUT=
OPENLIGADB_SEASON=

# --- LoL sources ---
DATADRAGON_LOCALE=es_MX

# --- Optional API keys (leave empty if unused) ---
RIOT_API_KEY=
THESPORTSDB_API_KEY=
RIOT_ESPORTS_ACCESS=
LEAGUEPEDIA_USER_AGENT=PirapireLocal/1.0

# --- Sync windows ---
SYNC_DEFAULT_LOOKBACK_DAYS=30
SYNC_DEFAULT_LOOKAHEAD_DAYS=14
