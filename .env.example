# --- App ---
APP_NAME=Pirapire
APP_ENV=local
APP_TIMEZONE=America/Argentina/Buenos_Aires
# Optional public URL (only for display/links). App works fine if empty.
APP_PUBLIC_URL=
DATABASE_URL=sqlite:////app/data/pirapire.db
LOG_LEVEL=INFO

# --- Deployment (used by docker-compose.yml) ---
PIRAPIRE_PORT=8090
PIRAPIRE_CONTAINER_NAME=pirapire_app

# --- Football sources ---
FOOTBALL_DATA_API_KEY=
FOOTBALL_DATA_BASE_URL=https://api.football-data.org/v4
FOOTBALL_DATA_COMPETITIONS=WC,CL,PL,BL1,SA,PD,FL1
FOOTBALL_DATA_REQUEST_DELAY_SECONDS=7
FOOTBALL_DATA_MAX_COMPETITIONS_PER_RUN=3
FOOTBALL_DATA_RESPECT_RETRY_AFTER=true
OPENLIGADB_LEAGUE_SHORTCUT=
OPENLIGADB_SEASON=

# --- LoL sources ---
DATADRAGON_LOCALE=es_MX

# --- Optional API keys (leave empty if unused) ---
RIOT_API_KEY=
THESPORTSDB_API_KEY=
RIOT_ESPORTS_ACCESS=
LEAGUEPEDIA_USER_AGENT=PirapireLocal/1.0

# --- Sync windows ---
SYNC_DEFAULT_LOOKBACK_DAYS=30
SYNC_DEFAULT_LOOKAHEAD_DAYS=14

# --- Aposta.LA (no browser worker by default; recommender uses CSV imports) ---
APOSTA_SYNC_ENABLED=false
APOSTA_BROWSER_WORKER_URL=

# --- Recommendation engine ---
RECOMMENDER_DEFAULT_MODE=probability
RECOMMENDER_MIN_PROBABILITY=0.55
RECOMMENDER_MAX_COMBO_LEGS=3
RECOMMENDER_MAX_SUGGESTIONS=20

# Aposta.LA snapshot import/capture
APOSTA_SYNC_ENABLED=true
APOSTA_SYNC_MODE=csv_folder
APOSTA_JSON_URL=
APOSTA_BROWSER_WORKER_URL=
APOSTA_IMPORT_DIR=/app/data/imports/aposta
APOSTA_ARCHIVE_DIR=/app/data/imports/archive
APOSTA_ERROR_DIR=/app/data/imports/errors
AUTO_RECOMMEND_ON_APOSTA_SYNC=true
AUTO_SYNC_SPORTS_BEFORE_RECOMMEND=true
SOURCE_STALE_HOURS=12
RECOMMENDER_MIN_EDGE=0.02
RECOMMENDER_MIN_EV=0.00
RECOMMENDER_ONLY_POSITIVE_EV=false
RECOMMENDER_MIN_MATCH_CONFIDENCE=0.70
RECOMMENDER_INCLUDE_STALE_ODDS=false

# LoL historical competitive data
LOL_HISTORY_ENABLED=true
LOL_HISTORY_START_YEAR=2021
LOL_HISTORY_END_YEAR=auto
LOL_HISTORY_ACTIVE_LEAGUES=LCK,LPL,LEC,LCS,CBLOL,LCP,MSI,WORLDS,FIRST_STAND
LOL_HISTORY_INCLUDE_LEGACY=true
LOL_HISTORY_LEGACY_LEAGUES=LTA,LLA,PCS,VCS,LJL,LCO,TCL,LCL
LOL_HISTORY_IMPORT_ON_STARTUP=false
LOL_HISTORY_REFRESH_HOURS=24
LOL_HISTORY_MIN_GAMES_TEAM=8
LOL_HISTORY_MIN_GAMES_PLAYER=5
LOL_HISTORY_RECENT_GAMES_WINDOW=20
LOL_HISTORY_PATCH_WEIGHTING=true
LOL_HISTORY_PATCH_HALF_LIFE=3
LOL_HISTORY_SOURCE_PRIORITY=oracles_elixir,lolesports,leaguepedia
LOL_APOSTA_MIN_MATCH_CONFIDENCE=0.70
LOL_HISTORY_IMPORT_DIR=/app/data/imports/oracles
LOL_HISTORY_ALLOW_DOWNLOAD=false
LOL_HISTORY_DOWNLOAD_URL_TEMPLATE=
