APP_NAME=Pirapire
APP_ENV=local
APP_TIMEZONE=America/Asuncion
DATABASE_URL=sqlite:////app/data/pirapire.db
LOG_LEVEL=INFO

PIRAPIRE_PORT=8090
PIRAPIRE_CONTAINER_NAME=pirapire_app

DATADRAGON_LOCALE=es_MX
LEAGUEPEDIA_USER_AGENT=PirapireLocal/1.0

LOL_HISTORY_ENABLED=true
LOL_HISTORY_ACTIVE_LEAGUES=LCK,LPL,LEC,LCS,CBLOL,LCP,MSI,WORLDS,FIRST_STAND
LOL_HISTORY_IMPORT_DIR=/app/data/imports/oracles
LOL_ODDS_IMPORT_DIR=/app/data/imports/lol_odds

LOL_SCHEDULE_INTERVAL_MINUTES=30
LOL_HISTORY_INTERVAL_MINUTES=240
DATADRAGON_INTERVAL_MINUTES=1440
